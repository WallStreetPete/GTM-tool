# Copy this file to ".env.local" and fill in what you have, then restart `npm run dev`.
# Everything is optional — with no keys the app runs in "demo mode" end-to-end.

# ── AI generation (writes the personalized opener lines) ─────────────────────
# Without this the app uses deterministic placeholder lines ("demo mode").
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: override the model (default: claude-sonnet-4-6). Use claude-haiku-4-5
# for cheaper bulk runs.
# AI_MODEL=claude-sonnet-4-6

# Optional alternative to ANTHROPIC_API_KEY: route through Vercel AI Gateway.
# AI_GATEWAY_API_KEY=

# ── Lead enrichment (deep background for hyper-personalization) ──────────────
# Waterfall order: LinkedIn -> Apollo -> Exa -> heuristic.
# Add only what you want; you do NOT need all of them.

# 1) Fresh LinkedIn Profile Data (RapidAPI): full profile from a LinkedIn URL —
#    headline, "about", full work history, education, skills. This is the one.
#    https://rapidapi.com/freshdata-freshdata-default/api/fresh-linkedin-profile-data
RAPIDAPI_KEY=
# Default host is already correct; only set this to override:
# RAPIDAPI_LINKEDIN_HOST=fresh-linkedin-profile-data.p.rapidapi.com

# 2) Apollo.io people enrichment — fallback for leads with no LinkedIn URL
#    (matches on email or name + company). https://docs.apollo.io/reference/people-enrichment
APOLLO_API_KEY=

# 3) Exa public web search (compliant fallback, summarized by the model).
#    https://exa.ai
EXA_API_KEY=
